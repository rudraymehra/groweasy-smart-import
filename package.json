{
  "name": "groweasy-smart-import",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered CSV importer that maps any CSV format into GrowEasy CRM leads",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w packages/shared",
    "dev": "npm-run-all --parallel dev:api dev:web",
    "dev:api": "npm run dev -w apps/api",
    "dev:web": "npm run dev -w apps/web",
    "build": "npm run build -w packages/shared && npm run build -w apps/api && npm run build -w apps/web",
    "test": "npm run test -w apps/api",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\""
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "playwright": "^1.61.1",
    "prettier": "^3.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
