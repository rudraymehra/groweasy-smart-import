# Required — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=4000
ALLOWED_ORIGIN=http://localhost:3000

# AI models (defaults shown). Haiku handles the high-volume row extraction
# cheaply; Sonnet handles the single, harder header-mapping call.
EXTRACTION_MODEL=claude-haiku-4-5
MAPPING_MODEL=claude-sonnet-5

# Batch tuning
BATCH_SIZE=30
MAX_CONCURRENCY=4

# Upload limit
MAX_FILE_SIZE_MB=20
